# Copy this file to .env.local for local development.
# In production, add these as Environment Variables in your Vercel project settings.

# MailerLite (free plan covers up to 1,000 subscribers)
# 1. Sign up free at https://www.mailerlite.com
# 2. Go to Integrations > API and generate an API key
# 3. Create a subscriber Group and copy its Group ID
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# GitHub OAuth App (powers the /admin content editor at yoursite.vercel.app/admin)
# See README.md "Setting Up the Admin Editor" section for full setup steps.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
